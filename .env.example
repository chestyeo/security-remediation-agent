DEVIN_API_KEY=cog_your_service_user_key
DEVIN_ORG_ID=your_org_id
GITHUB_TOKEN=your_github_token
TARGET_REPO=https://github.com/your-username/your-repo-name
SARIF_PATH=../your-repo-name/findings/codeql.sarif.json

# Optional
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# REPO_CRITICAL=true   # adds 20 points to every finding's priority score
# LOG_LEVEL=DEBUG      # surfaces prompt SHA256 tracing and full Devin response bodies
