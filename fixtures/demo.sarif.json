{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "semanticVersion": "2.15.0",
          "rules": [
            {
              "id": "py/sql-injection",
              "name": "SqlInjection",
              "shortDescription": { "text": "Database query built from user-controlled sources" },
              "properties": { "security-severity": "8.8", "tags": ["security", "external/cwe/cwe-089"] }
            },
            {
              "id": "py/hardcoded-credentials",
              "name": "HardcodedCredentials",
              "shortDescription": { "text": "Hard-coded credentials" },
              "properties": { "security-severity": "9.8", "tags": ["security", "external/cwe/cwe-798"] }
            },
            {
              "id": "py/unsafe-deserialization",
              "name": "UnsafeDeserialization",
              "shortDescription": { "text": "Deserialization of user-controlled data" },
              "properties": { "security-severity": "8.1", "tags": ["security", "external/cwe/cwe-502"] }
            },
            {
              "id": "py/path-injection",
              "name": "PathInjection",
              "shortDescription": { "text": "Uncontrolled data used in path expression" },
              "properties": { "security-severity": "7.5", "tags": ["security", "external/cwe/cwe-022"] }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "py/sql-injection",
          "ruleIndex": 0,
          "level": "error",
          "message": { "text": "This SQL query depends on a user-provided value." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/payments.py" },
                "region": { "startLine": 20 }
              }
            }
          ]
        },
        {
          "ruleId": "py/hardcoded-credentials",
          "ruleIndex": 1,
          "level": "error",
          "message": { "text": "Hardcoded credential found in source code." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/config/settings.py" },
                "region": { "startLine": 8 }
              }
            }
          ]
        },
        {
          "ruleId": "py/unsafe-deserialization",
          "ruleIndex": 2,
          "level": "error",
          "message": { "text": "Unsafe deserialization of user-controlled data via pickle." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/api/handlers.py" },
                "region": { "startLine": 45 }
              }
            }
          ]
        },
        {
          "ruleId": "py/path-injection",
          "ruleIndex": 3,
          "level": "error",
          "message": { "text": "Uncontrolled data used in path expression." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/utils/file_handler.py" },
                "region": { "startLine": 67 }
              }
            }
          ]
        }
      ]
    }
  ]
}
